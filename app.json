{
  "expo": {
    "name": "Control System List",
    "slug": "control-system-list",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "control-system-list",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050810"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.controlsystemlist"
    },
    "android": {
      "package": "com.controlsystemlist",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#050810"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-av",
      "expo-battery",
      "expo-device",
      "expo-network",
      "expo-brightness",
      "expo-screen-orientation"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}